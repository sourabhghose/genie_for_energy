{
  "datasets": [
    {
      "name": "kpi_summary",
      "displayName": "KPI Summary",
      "queryLines": [
        "SELECT COUNT(*) as total_customers,   SUM(CASE WHEN has_solar THEN 1 ELSE 0 END) as solar_customers,   ROUND(SUM(CASE WHEN has_solar THEN 1 ELSE 0 END) * 100.0 / COUNT(*), 1) as solar_pct,   SUM(CASE WHEN has_ev THEN 1 ELSE 0 END) as ev_customers FROM main.sourabh_energy_workshop.raw_customers "
      ]
    },
    {
      "name": "outage_kpi",
      "displayName": "Outage KPI",
      "queryLines": [
        "SELECT COUNT(*) as total_outages,   ROUND(AVG(duration_minutes), 0) as avg_duration_min,   SUM(affected_meters_count) as total_affected FROM main.sourabh_energy_workshop.raw_outages "
      ]
    },
    {
      "name": "billing_kpi",
      "displayName": "Billing KPI",
      "queryLines": [
        "SELECT ROUND(SUM(amount_charged), 0) as total_revenue,   ROUND(SUM(total_kwh)/1000, 0) as total_mwh FROM main.sourabh_energy_workshop.raw_billing "
      ]
    },
    {
      "name": "consumption_by_state",
      "displayName": "Consumption by State",
      "queryLines": [
        "SELECT c.state,   ROUND(SUM(m.kwh_consumed)/1000, 0) as total_mwh,   COUNT(DISTINCT m.meter_id) as meters FROM main.sourabh_energy_workshop.raw_meter_readings m JOIN main.sourabh_energy_workshop.raw_customers c ON m.customer_id = c.account_id GROUP BY c.state ORDER BY total_mwh DESC "
      ]
    },
    {
      "name": "customer_type_breakdown",
      "displayName": "Customer Type Breakdown",
      "queryLines": [
        "SELECT customer_type, state, COUNT(*) as customer_count FROM main.sourabh_energy_workshop.raw_customers GROUP BY customer_type, state "
      ]
    },
    {
      "name": "outage_by_cause",
      "displayName": "Outages by Cause",
      "queryLines": [
        "SELECT cause, state, COUNT(*) as outage_count FROM main.sourabh_energy_workshop.raw_outages GROUP BY cause, state "
      ]
    },
    {
      "name": "monthly_revenue",
      "displayName": "Monthly Revenue",
      "queryLines": [
        "SELECT billing_period,   ROUND(SUM(amount_charged), 0) as total_revenue,   ROUND(SUM(total_kwh)/1000, 0) as total_mwh FROM main.sourabh_energy_workshop.raw_billing GROUP BY billing_period ORDER BY billing_period "
      ]
    },
    {
      "name": "rate_plan_dist",
      "displayName": "Rate Plan Distribution",
      "queryLines": [
        "SELECT rate_plan, COUNT(*) as customer_count FROM main.sourabh_energy_workshop.raw_customers GROUP BY rate_plan ORDER BY customer_count DESC "
      ]
    },
    {
      "name": "equipment_risk",
      "displayName": "Equipment at Risk",
      "queryLines": [
        "SELECT equipment_id, equipment_type, state,   ROUND(current_load_pct, 1) as load_pct,   failure_count, install_date FROM main.sourabh_energy_workshop.raw_equipment WHERE current_load_pct > 85 ORDER BY current_load_pct DESC LIMIT 15 "
      ]
    },
    {
      "name": "outage_locations",
      "displayName": "Outage Locations",
      "queryLines": [
        "SELECT latitude, longitude, cause,   affected_meters_count, state, duration_minutes FROM main.sourabh_energy_workshop.raw_outages WHERE latitude IS NOT NULL AND longitude IS NOT NULL "
      ]
    }
  ],
